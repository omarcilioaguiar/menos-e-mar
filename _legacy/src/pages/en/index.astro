---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog'))
	.filter(post => post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const lang = 'en';
---

<BaseLayout title="Menos e Mar — Life Project & Tech" description="Exploring how to create what truly matters with fewer resources.">
	<Header lang={lang} />
	
	<section class="hero">
		<div class="hero-inner">
			<p class="hero-eyebrow">life project & technology</p>
			<h1 class="hero-title">Creating with <em>Less</em>,<br />Being more <em>Sea</em>.</h1>
			<p class="hero-sub">Exploring how to create what truly matters with fewer resources. A personal project by Marcílio.</p>
			
			<div class="hero-actions">
				<a href="https://omarcilioaguiar.vercel.app" target="_blank" class="cta-button outline-cta">
					Professional Site
				</a>
				<a href="https://www.linkedin.com/in/omarcilioaguiar/" target="_blank" class="cta-button outline-cta">
					LinkedIn
				</a>
			</div>
		</div>
		<div class="hero-line"></div>
	</section>

	<main class="main-content">
		<div class="container">
			<div class="section-label">
				<span>Recent Posts</span>
			</div>

			<div class="posts-grid">
				{posts.map((post) => (
					<article class="post-card">
						<div class="post-card-inner">
							<div class="post-meta-top">
								<FormattedDate date={post.data.pubDate} />
							</div>
							
							{post.data.heroImage && (
								<div class="post-thumbnail">
									<a href={`/${lang}/blog/${post.id.split('/')[1].replace(/\.mdx?$/, '')}`}>
										<img src={post.data.heroImage} alt="" />
									</a>
								</div>
							)}

							<h2 class="post-title">
								<a href={`/${lang}/blog/${post.id.split('/')[1].replace(/\.mdx?$/, '')}`}>{post.data.title}</a>
							</h2>
							<p class="post-excerpt">{post.data.description}</p>
							<div class="post-footer">
								<a href={`/${lang}/blog/${post.id.split('/')[1].replace(/\.mdx?$/, '')}`} class="read-more">Read more →</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</div>
	</main>

	<Footer lang={lang} />
</BaseLayout>

<style>
	/* Same styles as PT index */
	.hero {
		padding: 4rem 0 2rem;
		text-align: center;
	}
	.hero-inner {
		max-width: 740px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.hero-eyebrow {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: 1rem;
	}
	.hero-title {
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 6vw, 3.8rem);
		font-weight: 900;
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}
	.hero-title em { color: var(--accent); font-style: italic; }
	.hero-sub {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto 2.5rem;
	}
	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.outline-cta {
		padding: 0.6rem 1.25rem;
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		transition: all 0.2s;
	}
	.outline-cta:hover {
		border-color: var(--accent);
		color: var(--text);
		background: var(--accent-soft);
	}
	.hero-line {
		height: 1px;
		background: linear-gradient(to right, transparent, var(--border), transparent);
		margin-top: 4rem;
	}

	.section-label {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin: 3rem 0 2rem;
		color: var(--text-faint);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
	}
	.section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

	.post-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 8px;
		margin-bottom: 2rem;
		overflow: hidden;
		transition: transform 0.2s, border-color 0.2s;
	}
	.post-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
	}
	.post-card-inner { padding: 2rem; }
	.post-meta-top {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-faint);
		margin-bottom: 1rem;
	}
	.post-thumbnail { margin-bottom: 1.5rem; border-radius: 4px; overflow: hidden; }
	.post-thumbnail img { width: 100%; display: block; }
	.post-title {
		font-family: var(--font-display);
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}
	.post-title a { color: var(--text); }
	.post-excerpt { color: var(--text-muted); margin-bottom: 1.5rem; }
	.post-footer { border-top: 1px solid var(--border); padding-top: 1rem; }
	.read-more { font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600; }
</style>
