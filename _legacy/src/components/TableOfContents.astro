---
interface Props {
	headings: { depth: number; slug: string; text: string }[];
	lang?: 'pt' | 'en';
}

const { headings, lang = 'pt' } = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);

const t = {
	pt: 'Nesta página',
	en: 'On this page'
};
---

{filteredHeadings.length > 0 && (
	<nav class="toc-sidebar">
		<div class="toc-title">{t[lang]}</div>
		<ul class="toc-list">
			{filteredHeadings.map((heading) => (
				<li class={`toc-depth-${heading.depth}`}>
					<a href={`#${heading.slug}`} class="toc-link">
						{heading.text}
					</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc-depth-3 {
		padding-left: 1rem;
		font-size: 0.8rem;
	}
</style>

<script>
	// Simple ScrollSpy implementation
	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			const id = entry.target.getAttribute('id');
			if (entry.isIntersecting) {
				document.querySelectorAll('.toc-link').forEach((link) => {
					link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
				});
			}
		});
	}, { rootMargin: '0px 0px -80% 0px' });

	document.querySelectorAll('h2, h3').forEach((section) => {
		observer.observe(section);
	});
</script>
